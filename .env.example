# Studio environment variables
DATABASE_URL=postgresql+asyncpg://citycast:citycast@localhost:5432/citycast

# Ollama (runs on host Mac)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=mistral

# Piper TTS (runs on host Mac)
PIPER_MODEL_PATH=./models/en_US-lessac-medium.onnx

# S3 storage
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=citycast-audio
S3_ENDPOINT_URL=

# Portal auth
PORTAL_PASSWORD=dev
PORTAL_ALLOWED_IPS=0.0.0.0/0

# Email (for ad approval workflow)
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=studio@localhost
